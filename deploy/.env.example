# Copy this file to `.env` and adjust the values, then `docker compose up -d`.
# Do NOT commit your real `.env`.

# Webapp image on GHCR. Replace OWNER with your GitHub owner/org. The package is
# public, so no GHCR login is needed to pull. Pin a tag (e.g. :sha-abc1234 or a
# semver) instead of :latest for reproducible deploys.
WEBAPP_IMAGE=ghcr.io/OWNER/ambilighthue/webapp:latest

# Shared secret guarding /api/* (except /api/health). If set, clients must send
# the X-API-Token header. The Homebridge config.json and your Apple Shortcuts
# must use the same value. Use an unguessable string in production.
API_TOKEN=change-me

# Sub-path the webapp is served under behind Caddy. MUST match the path in the
# Caddyfile `handle` block. Empty = served at root.
BASE_PATH=/ambilight

# Timezone for the Homebridge container (e.g. Europe/Berlin).
TZ=Etc/UTC
